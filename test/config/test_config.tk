m=test.config;
i=config:ooke.config;
i=test:std.test;
i=file:std.file;
i=str:std.str;

f=testloadvalid():bool{
  let tomlsrc="[site]\nname = \"ooke-test\"\nurl = \"https://test.example.com\"\nlanguage = \"fr\"\n\n[build]\noutput = \"dist/\"\nminify = false\ninlinecss = false\n\n[server]\nport = 8080\nworkers = 2\n\n[store]\nbackend = \"flat\"\n";
  let writeresult=file.write("/tmp/test_ooke.toml";tomlsrc);
  mt writeresult{
    ok(v){};
    err(e){<false}
  };
  let result=config.configload("/tmp/test_ooke.toml");
  (mt result{
    ok(cfg){
      (test.eq(cfg.sitename;"ooke-test"));
      (test.eq(cfg.siteurl;"https://test.example.com"));
      (test.eq(cfg.sitelanguage;"fr"));
      (test.eq(cfg.buildoutput;"dist/"));
      (test.eq(cfg.serverport;8080));
      (test.eq(cfg.serverworkers;2));
      (test.eq(cfg.storebackend;"flat"));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

f=testmissingfile():bool{
  let result=config.configload("/nonexistent/path.toml");
  (mt result{
    ok(cfg){
      (test.fail("expected error for missing file"));
      <false
    };
    err(e){
      <str.contains(e.msg;"cannot read config")
    }
  })
};

f=testdefaults():bool{
  let tomlsrc="[site]\nname = \"x\"\n";
  let writeresult=file.write("/tmp/test_ooke_defaults.toml";tomlsrc);
  mt writeresult{
    ok(v){};
    err(e){<false}
  };
  let result=config.configload("/tmp/test_ooke_defaults.toml");
  (mt result{
    ok(cfg){
      (test.eq(cfg.sitename;"x"));
      (test.eq(cfg.siteurl;""));
      (test.eq(cfg.sitelanguage;"en"));
      (test.eq(cfg.buildoutput;"build/"));
      (test.eq(cfg.buildminify;true));
      (test.eq(cfg.buildinlinecss;true));
      (test.eq(cfg.serverport;3000));
      (test.eq(cfg.serverworkers;4));
      (test.eq(cfg.storebackend;"flat"));
      (test.eq(cfg.logaccess;"logs/access.log"));
      (test.eq(cfg.logmaxlines;10000));
      (test.eq(cfg.logmaxagedays;30));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

f=main():i64{
  let r0=testloadvalid();
  let r1=testmissingfile();
  let r2=testdefaults();
  if(r0&&r1&&r2){
    <0
  }el{
    <1
  }
};
