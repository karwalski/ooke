m=test.router;
i=router:ooke.router;
i=test:std.test;
i=str:std.str;
i=file:std.file;

(* Create a temporary pages directory with a set of .tk page files,
   call routerscan, and verify that the expected patterns are present. *)
f=testscanbasic():bool{
  let tmp=file.tempdir()!$router.$routeerr;
  (file.mkdir(str.concat(tmp;"/blog")));
  (file.write(str.concat(tmp;"/index.tk");""));
  (file.write(str.concat(tmp;"/about.tk");""));
  (file.write(str.concat(tmp;"/blog/[slug].tk");""));
  let result=router.routerscan(tmp);
  mt result{
    ok(routes){
      let foundroot=mut.false;
      let foundabout=mut.false;
      let foundblog=mut.false;
      let foundblogdynamic=mut.false;
      lp(let i=mut.0;i<routes.len;i=i+1){
        let r=routes.get(i);
        if(r.pattern=="/"){foundroot=true};
        if(r.pattern=="/about"){foundabout=true};
        if(r.pattern=="/blog/:slug"){
          foundblog=true;
          foundblogdynamic=r.isdynamic
        }
      };
      <foundroot&&foundabout&&foundblog&&foundblogdynamic
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  }
};

(* Build a static route list manually and verify that an exact URL match
   succeeds with an empty params map. *)
f=testmatchstatic():bool{
  let r=$router.$route{
    pattern:"/about";
    filepath:"pages/about.tk";
    templatepath:"templates/about.tkt";
    contenttype:"";
    isdynamic:false;
    isapi:false;
    params:@()
  };
  let routes=@(r);
  let result=router.routermatch(routes;"/about");
  mt result{
    ok(m){
      <m.params.len==0
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  }
};

(* Build a dynamic route and verify that the captured param is extracted
   correctly from the URL. *)
f=testmatchdynamic():bool{
  let r=$router.$route{
    pattern:"/blog/:slug";
    filepath:"pages/blog/[slug].tk";
    templatepath:"templates/blog.tkt";
    contenttype:"blog";
    isdynamic:true;
    isapi:false;
    params:@()
  };
  let routes=@(r);
  let result=router.routermatch(routes;"/blog/hello-world");
  mt result{
    ok(m){
      let slug=mt m.params.get("slug"){
        ok(v){<v};
        err(e){<""}
      };
      <slug=="hello-world"
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  }
};

(* Verify that a URL with no matching route returns an error. *)
f=testmatchnomatch():bool{
  let r=$router.$route{
    pattern:"/about";
    filepath:"pages/about.tk";
    templatepath:"templates/about.tkt";
    contenttype:"";
    isdynamic:false;
    isapi:false;
    params:@()
  };
  let routes=@(r);
  let result=router.routermatch(routes;"/nonexistent");
  mt result{
    ok(m){<false};
    err(e){<true};
  }
};

(* Verify that the root URL "/" matches a route with pattern "/". *)
f=testmatchroot():bool{
  let r=$router.$route{
    pattern:"/";
    filepath:"pages/index.tk";
    templatepath:"templates/index.tkt";
    contenttype:"";
    isdynamic:false;
    isapi:false;
    params:@()
  };
  let routes=@(r);
  let result=router.routermatch(routes;"/");
  mt result{
    ok(m){<true};
    err(e){
      (test.fail(e.msg));
      <false
    };
  }
};

(* Verify that a more specific dynamic route (fewer dynamic segments)
   is preferred over a less specific one. *)
f=testmatchspecificity():bool{
  let generic=$router.$route{
    pattern:"/docs/:section/:slug";
    filepath:"pages/docs/[section]/[slug].tk";
    templatepath:"templates/docs/[section]/[slug].tkt";
    contenttype:"docs";
    isdynamic:true;
    isapi:false;
    params:@()
  };
  let specific=$router.$route{
    pattern:"/docs/about/:slug";
    filepath:"pages/docs/about/[slug].tk";
    templatepath:"templates/docs/about/[slug].tkt";
    contenttype:"docs/about";
    isdynamic:true;
    isapi:false;
    params:@()
  };
  let routes=@(generic;specific);
  let result=router.routermatch(routes;"/docs/about/overview");
  mt result{
    ok(m){
      <m.route.pattern=="/docs/about/:slug"
    };
    err(e){
      (test.fail(e.msg));
      <false
    };
  }
};

f=main():i64{
  let r0=testscanbasic();
  let r1=testmatchstatic();
  let r2=testmatchdynamic();
  let r3=testmatchnomatch();
  let r4=testmatchroot();
  let r5=testmatchspecificity();
  if(r0&&r1&&r2&&r3&&r4&&r5){
    <0
  }el{
    <1
  }
};
