m=test.store;
i=store:ooke.store;
i=test:std.test;
i=file:std.file;
i=str:std.str;

f=testparsefrontmatter():bool{
  let src="---\nslug: hello-world\ntype: post\ntitle: Hello World\n---\n# Hello\n\nThis is the body.\n";
  let result=store.storeparsefront(src);
  (mt result{
    ok(c){
      (test.eq(c.slug;"hello-world"));
      (test.eq(c.type;"post"));
      (test.eq(str.contains(c.body;"Hello")&&str.contains(c.body;"body");true));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

f=teststoreallempty():bool{
  let mkresult=file.mkdir("/tmp/test_store_empty/posts");
  mt mkresult{
    ok(v){};
    err(e){}
  };
  let result=store.storeall("/tmp/test_store_empty";"posts";"flat");
  (mt result{
    ok(col){
      (test.eq(col.len;0));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

f=teststoreslug():bool{
  let c1=store.$content{
    slug:"about";
    type:"page";
    title:"";
    meta:@($str:$str);
    body:"About page body"
  };
  let c2=store.$content{
    slug:"contact";
    type:"page";
    title:"";
    meta:@($str:$str);
    body:"Contact page body"
  };
  let col=@(c1;c2);
  let result=store.storeslug(col;"contact");
  (mt result{
    ok(c){
      (test.eq(c.slug;"contact"));
      (test.eq(str.contains(c.body;"Contact");true));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

f=main():i64{
  let r0=testparsefrontmatter();
  let r1=teststoreallempty();
  let r2=teststoreslug();
  if(r0&&r1&&r2){
    <0
  }el{
    <1
  }
};
