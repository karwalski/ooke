f=testfilterescape():bool{
  let src="{= text | escape =}";
  let ctx=@("text":"<script>alert(1)</script>");
  let tokens=tpl.tpllex(src);
  (mt tokens{
    ok(toks){
      let out=tpl.tplrender(toks;ctx;"/tmp";@());
      (mt out{
        ok(s){
          (test.eq(str.contains(s;"&lt;script&gt;");true));
          (test.eq(str.contains(s;"<script>");false));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};


f=testcommentignored():bool{
  let src="before{# this is a comment #}after";
  let ctx=@($str:$str);
  let tokens=tpl.tpllex(src);
  (mt tokens{
    ok(toks){
      let out=tpl.tplrender(toks;ctx;"/tmp";@());
      (mt out{
        ok(s){
          (test.eq(str.contains(s;"comment");false));
          (test.eq(str.contains(s;"before");true));
          (test.eq(str.contains(s;"after");true));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};


f=testlayoutdetected():bool{
  let src="{! layout(\"base\") !}<p>child content</p>";
  let tokens=tpl.tpllex(src);
  (mt tokens{
    ok(toks){
      
      (test.eq(toks.len>=2;true));
      let first=toks.get(0);
      (test.eq(first.kind.directive;true));
      (test.eq(str.contains(first.content;"layout");true));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};


