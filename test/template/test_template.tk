m=test.template;
i=tpl:ooke.template;
i=test:std.test;
i=str:std.str;
i=file:std.file;




f=testrawpassthrough():bool{
  let src="<p>Hello, world!</p>";
  let tokens=tpl.tpllex(src);
  (mt tokens{
    ok(toks){
      let ctx=@($str:$str);
      let out=tpl.tplrender(toks;ctx;"/tmp";@());
      (mt out{
        ok(s){
          (test.eq(s;src));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};


f=testexprsimple():bool{
  let src="Hello, {= name =}!";
  let ctx=@("name":"World");
  let tokens=tpl.tpllex(src);
  (mt tokens{
    ok(toks){
      let out=tpl.tplrender(toks;ctx;"/tmp";@());
      (mt out{
        ok(s){
          (test.eq(str.contains(s;"World");true));
          (test.eq(str.contains(s;"Hello");true));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};


