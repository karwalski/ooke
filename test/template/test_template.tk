    ok(toks){
      
      (test.eq(toks.len;3));
      let out=tpl.tplrender(toks;ctx;"/tmp";@());
      (mt out{
        ok(s){
          
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
