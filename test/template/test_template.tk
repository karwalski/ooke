m=test.template;
i=tpl:ooke.template;
i=test:std.test;
i=str:std.str;
i=file:std.file;

(* ===================================================================
   test_template.tk — unit tests for ooke.template

   Run 15 tests covering: lexer, renderer, filters, escaping,
   layout detection, block collection, partials, and the cache.
   =================================================================== *)

(* 1. Raw passthrough — a template with no delimiters returns itself. *)
f=test_raw_passthrough():bool{
  let src="<p>Hello, world!</p>";
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let ctx=@($str:$str);
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(s;src));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 2. Simple expression substitution: {= name =} with ctx ("name":"World"). *)
f=test_expr_simple():bool{
  let src="Hello, {= name =}!";
  let ctx=@("name":"World");
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(str.contains(s;"World");true));
          (test.eq(str.contains(s;"Hello");true));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 3. Missing key in ctx yields empty string, no crash. *)
f=test_expr_missing_key():bool{
  let src="{= missing_key =}";
  let ctx=@($str:$str);
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(s;""));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 4. Dotted key: {= site.name =} with ctx ("site.name":"toke"). *)
f=test_dotted_key():bool{
  let src="Site: {= site.name =}";
  let ctx=@("site.name":"toke");
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(str.contains(s;"toke");true));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 5. Filter md: {= body | md =} with body "# Hello" should produce <h1>. *)
f=test_filter_md():bool{
  let src="{= body | md =}";
  let ctx=@("body":"# Hello");
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(str.contains(s;"<h1");true));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 6. Filter upper: {= name | upper =} uppercases the value. *)
f=test_filter_upper():bool{
  let src="{= name | upper =}";
  let ctx=@("name":"toke");
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(s;"TOKE"));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 7. Filter escape: {= text | escape =} with <script> → &lt;script&gt;. *)
f=test_filter_escape():bool{
  let src="{= text | escape =}";
  let ctx=@("text":"<script>alert(1)</script>");
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(str.contains(s;"&lt;script&gt;");true));
          (test.eq(str.contains(s;"<script>");false));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 8. Comment: {# this is a comment #} should not appear in output. *)
f=test_comment_ignored():bool{
  let src="before{# this is a comment #}after";
  let ctx=@($str:$str);
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (test.eq(str.contains(s;"comment");false));
          (test.eq(str.contains(s;"before");true));
          (test.eq(str.contains(s;"after");true));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 9. Layout directive: {! layout("base") !} should lex without crash.
   We verify the directive token is present with "layout" content. *)
f=test_layout_detected():bool{
  let src="{! layout(\"base\") !}<p>child content</p>";
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      (* should have at least two tokens: directive + raw *)
      (test.eq(toks.len>=2;true));
      let first=toks.get(0);
      (test.eq(first.kind.directive;true));
      (test.eq(str.contains(first.content;"layout");true));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 10. Block collection: block/end pair is lexed and rendered without error. *)
f=test_block_collected():bool{
  let src="{! block(\"title\") !}My Title{! end !}";
  let ctx=@($str:$str);
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      (* three tokens: directive(block), raw, directive(end) *)
      (test.eq(toks.len;3));
      let out=tpl.tpl_render(toks;ctx;"/tmp";@());
      (match out{
        ok(s){
          (* block content is collected and not emitted in plain render *)
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 11. tpl_escape helper: "<b>&" → "&lt;b&gt;&amp;". *)
f=test_escape_helper():bool{
  let result=tpl.tpl_escape("<b>&");
  (test.eq(str.contains(result;"&lt;b&gt;");true));
  (test.eq(str.contains(result;"&amp;");true));
  (test.eq(str.contains(result;"<b>");false));
  <true
};

(* 12. Lex a mixed template and verify token count and types. *)
f=test_lex_basic():bool{
  let src="<p>{= title =}</p>{# ignore #}{! block(\"x\") !}body{! end !}";
  let tokens=tpl.tpl_lex(src);
  (match tokens{
    ok(toks){
      (* expected: raw("<p>"), expr("title"), raw("</p>"),
                   comment, directive(block), raw("body"), directive(end) *)
      (test.eq(toks.len;7));
      let t0=toks.get(0);
      (test.eq(t0.kind.raw;true));
      let t1=toks.get(1);
      (test.eq(t1.kind.expr;true));
      let t3=toks.get(3);
      (test.eq(t3.kind.comment;true));
      let t4=toks.get(4);
      (test.eq(t4.kind.directive;true));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 13. tpl_renderfile_simple — write a temp .tkt file and render it. *)
f=test_renderfile_simple():bool{
  let tkt_src="<h1>{= heading =}</h1><p>{= body =}</p>";
  let tkt_path="/tmp/test_ooke_simple.tkt";
  let write_result=file.write(tkt_path;tkt_src);
  (match write_result{
    ok(v){};
    err(e){
      (test.fail("could not write temp template"));
      <false
    }
  });
  let ctx=@("heading":"Welcome";"body":"Hello from ooke.");
  let result=tpl.tpl_renderfile(tkt_path;ctx;"/tmp");
  (match result{
    ok(s){
      (test.eq(str.contains(s;"<h1>Welcome</h1>");true));
      (test.eq(str.contains(s;"Hello from ooke.");true));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 14. Cache hit — rendering same path twice stores tokens in cache. *)
f=test_cache_hit():bool{
  let tkt_src="<p>{= msg =}</p>";
  let tkt_path="/tmp/test_ooke_cache.tkt";
  let write_result=file.write(tkt_path;tkt_src);
  (match write_result{
    ok(v){};
    err(e){
      (test.fail("could not write temp template"));
      <false
    }
  });
  let ctx=@("msg":"cached");
  let cache0=tpl.tpl_cache_new();

  (* first render — lex and cache *)
  let r1=tpl.tpl_renderfile_cached(tkt_path;ctx;"/tmp";cache0);
  (match r1{
    ok(rr1){
      (test.eq(str.contains(rr1.output;"cached");true));
      (* second render — should use cache; cache should contain the key *)
      let r2=tpl.tpl_renderfile_cached(tkt_path;ctx;"/tmp";rr1.cache);
      (match r2{
        ok(rr2){
          (test.eq(str.contains(rr2.output;"cached");true));
          (* verify key is now present in entries *)
          let has_entry=match rr2.cache.entries.get(tkt_path){
            ok(v){<true};
            err(e){<false}
          };
          (test.eq(has_entry;true));
          <true
        };
        err(e){
          (test.fail(e.msg));
          <false
        }
      })
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* 15. Partial inclusion: {! partial("header") !}
   Writes a header partial file, then renders a parent template that
   includes it, verifying the partial content appears in output. *)
f=test_partial():bool{
  let partial_src="<header><a href=\"/\">Home</a></header>";
  let partial_path="/tmp/header.tkt";
  let p_write=file.write(partial_path;partial_src);
  (match p_write{
    ok(v){};
    err(e){
      (test.fail("could not write partial"));
      <false
    }
  });
  let tkt_src="{! partial(\"header\") !}<main>{= content =}</main>";
  let tkt_path="/tmp/test_ooke_partial.tkt";
  let t_write=file.write(tkt_path;tkt_src);
  (match t_write{
    ok(v){};
    err(e){
      (test.fail("could not write template"));
      <false
    }
  });
  let ctx=@("content":"Hello from partial test.");
  let result=tpl.tpl_renderfile(tkt_path;ctx;"/tmp");
  (match result{
    ok(s){
      (test.eq(str.contains(s;"<header>");true));
      (test.eq(str.contains(s;"Home");true));
      (test.eq(str.contains(s;"Hello from partial test.");true));
      <true
    };
    err(e){
      (test.fail(e.msg));
      <false
    }
  })
};

(* ---- main: run all 15 tests ---- *)

f=main():i64{
  let r0=test_raw_passthrough();
  let r1=test_expr_simple();
  let r2=test_expr_missing_key();
  let r3=test_dotted_key();
  let r4=test_filter_md();
  let r5=test_filter_upper();
  let r6=test_filter_escape();
  let r7=test_comment_ignored();
  let r8=test_layout_detected();
  let r9=test_block_collected();
  let r10=test_escape_helper();
  let r11=test_lex_basic();
  let r12=test_renderfile_simple();
  let r13=test_cache_hit();
  let r14=test_partial();
  if(r0&&r1&&r2&&r3&&r4&&r5&&r6&&r7&&r8&&r9&&r10&&r11&&r12&&r13&&r14){
    <0
  }el{
    <1
  }
};
