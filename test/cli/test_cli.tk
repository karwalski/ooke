m=test.cli;
i=file:std.file;
i=str:std.str;
i=test:std.test;
i=path:std.path;
i=ookecli:ooke.cli;

(* Verify that clinew creates the expected directory structure and config file. *)
f=testnewcreatesdirs():bool{
  let proj="test_ooke_proj";
  let rc=ookecli.clinew(proj);
  if(rc!=0){
    (test.fail("clinew returned non-zero"));
    <false
  };
  let rootok=mt file.exists(proj){
    ok(v){<v};
    err(e){<false}
  };
  let pagesok=mt file.exists(path.join(proj;"pages")){
    ok(v){<v};
    err(e){<false}
  };
  let templatesok=mt file.exists(path.join(proj;"templates")){
    ok(v){<v};
    err(e){<false}
  };
  let contentok=mt file.exists(path.join(proj;"content")){
    ok(v){<v};
    err(e){<false}
  };
  let staticok=mt file.exists(path.join(proj;"static")){
    ok(v){<v};
    err(e){<false}
  };
  let tomlok=mt file.exists(path.join(proj;"ooke.toml")){
    ok(v){<v};
    err(e){<false}
  };
  let indexok=mt file.exists(path.join(path.join(proj;"pages");"index.tk")){
    ok(v){<v};
    err(e){<false}
  };
  let baseok=mt file.exists(path.join(path.join(proj;"templates");"base.tkt")){
    ok(v){<v};
    err(e){<false}
  };
  (file.removeall(proj));
  <rootok&&pagesok&&templatesok&&contentok&&staticok&&tomlok&&indexok&&baseok
};

(* Verify that clinew writes a valid ooke.toml containing the project name. *)
f=testnewtomlcontent():bool{
  let proj="test_ooke_toml";
  let rc=ookecli.clinew(proj);
  if(rc!=0){
    (test.fail("clinew returned non-zero"));
    <false
  };
  let tomlpath=path.join(proj;"ooke.toml");
  let readresult=file.read(tomlpath);
  let ok=mt readresult{
    ok(src){
      <str.contains(src;proj)&&str.contains(src;"[site]")&&str.contains(src;"[server]")
    };
    err(e){
      (test.fail("could not read ooke.toml"));
      <false
    }
  };
  (file.removeall(proj));
  <ok
};

(* Verify that cligen creates a page stub at pages/<name>.tk. *)
f=testgenpage():bool{
  let mkresult=file.mkdir("pages");
  mt mkresult{
    ok(v){};
    err(e){}
  };
  let rc=ookecli.cligen("page";"mypage");
  if(rc!=0){
    (test.fail("cligen page returned non-zero"));
    <false
  };
  let pagepath=path.join("pages";"mypage.tk");
  let exists=mt file.exists(pagepath){
    ok(v){<v};
    err(e){<false}
  };
  let contentok=mt file.read(pagepath){
    ok(src){<str.contains(src;"mypage")};
    err(e){<false}
  };
  (file.remove(pagepath));
  <exists&&contentok
};

(* Verify that cligen for an unknown type returns non-zero. *)
f=testgenunknowntype():bool{
  let rc=ookecli.cligen("unknowntype";"foo");
  <rc==1
};

(* Verify that cligen creates an api stub under pages/api/. *)
f=testgenapi():bool{
  let mkresult=file.mkdir(path.join("pages";"api"));
  mt mkresult{
    ok(v){};
    err(e){}
  };
  let rc=ookecli.cligen("api";"myapi");
  if(rc!=0){
    (test.fail("cligen api returned non-zero"));
    <false
  };
  let apipath=path.join(path.join("pages";"api");"myapi.tk");
  let exists=mt file.exists(apipath){
    ok(v){<v};
    err(e){<false}
  };
  (file.remove(apipath));
  <exists
};

f=main():i64{
  let r0=testnewcreatesdirs();
  let r1=testnewtomlcontent();
  let r2=testgenpage();
  let r3=testgenunknowntype();
  let r4=testgenapi();
  if(r0&&r1&&r2&&r3&&r4){
    <0
  }el{
    <1
  }
};
